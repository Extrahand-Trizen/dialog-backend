generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// AUTH & TENANCY
// =============================================================================

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  members                OrganizationMember[]
  apiKeys                ApiKey[]
  whatsAppAccounts       WhatsAppAccount[]
  templates              Template[]
  notificationRules      NotificationRule[]
  eventIngests           EventIngest[]
  notificationExecutions NotificationExecution[]
  messages               Message[]
  webhookEvents          WebhookEvent[]
  outboundWebhookConfig  OutboundWebhookConfig?

  @@index([isActive])
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String?
  firstName    String
  lastName     String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime? @db.Timestamptz(3)
  createdAt    DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(3)

  memberships OrganizationMember[]

  createdApiKeys           ApiKey[]           @relation("ApiKeyCreatedBy")
  createdWhatsAppAccounts  WhatsAppAccount[]  @relation("WhatsAppAccountCreatedBy")
  updatedWhatsAppAccounts  WhatsAppAccount[]  @relation("WhatsAppAccountUpdatedBy")
  createdPhoneNumbers      PhoneNumber[]      @relation("PhoneNumberCreatedBy")
  updatedPhoneNumbers      PhoneNumber[]      @relation("PhoneNumberUpdatedBy")
  createdTemplates         Template[]         @relation("TemplateCreatedBy")
  updatedTemplates         Template[]         @relation("TemplateUpdatedBy")
  createdTemplateVersions  TemplateVersion[]  @relation("TemplateVersionCreatedBy")
  createdNotificationRules NotificationRule[] @relation("NotificationRuleCreatedBy")
  updatedNotificationRules NotificationRule[] @relation("NotificationRuleUpdatedBy")
  revokedApiKeys           ApiKey[]           @relation("ApiKeyRevokedBy")
  deletedTemplates         Template[]         @relation("TemplateDeletedBy")
  deletedNotificationRules NotificationRule[] @relation("NotificationRuleDeletedBy")
  createdOutboundWebhooks  OutboundWebhookConfig[] @relation("OutboundWebhookCreatedBy")
  updatedOutboundWebhooks  OutboundWebhookConfig[] @relation("OutboundWebhookUpdatedBy")

  @@index([isActive])
}

enum UserRole {
  ADMIN
  VIEWER
}

model OrganizationMember {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  role           UserRole @default(VIEWER)
  createdAt      DateTime @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

// =============================================================================
// API KEYS
// =============================================================================

model ApiKey {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  keyPrefix      String
  keyHash        String
  scopes         String[]
  createdById    String?
  lastUsedAt     DateTime? @db.Timestamptz(3)
  expiresAt      DateTime? @db.Timestamptz(3)
  revokedAt      DateTime? @db.Timestamptz(3)
  revokedById    String?
  createdAt      DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime  @updatedAt @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("ApiKeyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  revokedBy    User?        @relation("ApiKeyRevokedBy", fields: [revokedById], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([keyPrefix])
  @@index([revokedAt])
}

// =============================================================================
// WHATSAPP
// =============================================================================

enum WhatsAppAccountStatus {
  ACTIVE
  ERROR
  DISCONNECTED
}

model WhatsAppAccount {
  id                 String                @id @default(uuid())
  organizationId     String
  metaWabaId         String
  name               String?
  accessTokenEnc     String
  appSecretEnc       String
  webhookVerifyToken String?
  status             WhatsAppAccountStatus @default(ACTIVE)
  lastSyncedAt       DateTime?             @db.Timestamptz(3)
  lastError          String?
  createdById        String?
  updatedById        String?
  createdAt          DateTime              @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime              @updatedAt @db.Timestamptz(3)

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?         @relation("WhatsAppAccountCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?         @relation("WhatsAppAccountUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  phoneNumbers PhoneNumber[]

  @@unique([organizationId, metaWabaId])
  @@index([organizationId, status])
}

enum PhoneNumberStatus {
  ACTIVE
  PENDING
  RESTRICTED
  INACTIVE
}

enum PhoneQualityRating {
  GREEN
  YELLOW
  RED
  UNKNOWN
}

model PhoneNumber {
  id                String             @id @default(uuid())
  whatsAppAccountId String
  metaPhoneNumberId String             @unique
  displayNumber     String
  verifiedName      String?
  qualityRating     PhoneQualityRating @default(UNKNOWN)
  messagingTier     String?
  status            PhoneNumberStatus  @default(PENDING)
  isDefault         Boolean            @default(false)
  lastHealthCheckAt DateTime?          @db.Timestamptz(3)
  createdById       String?
  updatedById       String?
  createdAt         DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime           @updatedAt @db.Timestamptz(3)

  whatsAppAccount   WhatsAppAccount    @relation(fields: [whatsAppAccountId], references: [id], onDelete: Cascade)
  createdBy         User?              @relation("PhoneNumberCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy         User?              @relation("PhoneNumberUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  messages          Message[]
  notificationRules NotificationRule[]

  @@index([whatsAppAccountId, isDefault])
  @@index([whatsAppAccountId, status])
  @@index([qualityRating])
}

// =============================================================================
// TEMPLATES
// =============================================================================

enum TemplateCategory {
  MARKETING
  UTILITY
  AUTHENTICATION
}

enum MetaTemplateStatus {
  APPROVED
  PENDING
  REJECTED
  PAUSED
  DISABLED
  DELETED
  UNKNOWN
}

model Template {
  id               String             @id @default(uuid())
  organizationId   String
  metaTemplateName String
  metaTemplateId   String?
  category         TemplateCategory
  language         String             @default("en")
  metaStatus       MetaTemplateStatus @default(UNKNOWN)
  currentVersionId String?            @unique
  createdById      String?
  updatedById      String?
  deletedAt        DateTime?          @db.Timestamptz(3)
  deletedById      String?
  createdAt        DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt        DateTime           @updatedAt @db.Timestamptz(3)

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  currentVersion    TemplateVersion?   @relation("TemplateCurrentVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)
  versions          TemplateVersion[]  @relation("TemplateVersions")
  notificationRules NotificationRule[]
  createdBy         User?              @relation("TemplateCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy         User?              @relation("TemplateUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedBy         User?              @relation("TemplateDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  @@unique([organizationId, metaTemplateName, language])
  @@index([organizationId, metaStatus])
  @@index([organizationId, deletedAt])
}

model TemplateVersion {
  id              String    @id @default(uuid())
  templateId      String
  version         Int
  components      Json
  variableSchema  Json
  rejectionReason String?
  submittedAt     DateTime? @db.Timestamptz(3)
  approvedAt      DateTime? @db.Timestamptz(3)
  createdById     String?
  createdAt       DateTime  @default(now()) @db.Timestamptz(3)

  template          Template                @relation("TemplateVersions", fields: [templateId], references: [id], onDelete: Cascade)
  currentFor        Template?               @relation("TemplateCurrentVersion")
  createdBy         User?                   @relation("TemplateVersionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  messages          Message[]
  notificationRules NotificationRule[]
  executions        NotificationExecution[]

  @@unique([templateId, version])
  @@index([templateId, createdAt(sort: Desc)])
}

// =============================================================================
// NOTIFICATION RULES
// =============================================================================

model NotificationRule {
  id                String    @id @default(uuid())
  organizationId    String
  eventKey          String
  name              String
  version           Int       @default(1)
  templateId        String
  templateVersionId String?
  phoneNumberId     String?
  variableMapping   Json
  enabled           Boolean   @default(true)
  priority          Int       @default(0)
  createdById       String?
  updatedById       String?
  deletedAt         DateTime? @db.Timestamptz(3)
  deletedById       String?
  createdAt         DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt         DateTime  @updatedAt @db.Timestamptz(3)

  organization    Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template        Template                @relation(fields: [templateId], references: [id], onDelete: Restrict)
  templateVersion TemplateVersion?        @relation(fields: [templateVersionId], references: [id], onDelete: SetNull)
  phoneNumber     PhoneNumber?            @relation(fields: [phoneNumberId], references: [id], onDelete: SetNull)
  createdBy       User?                   @relation("NotificationRuleCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy       User?                   @relation("NotificationRuleUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  deletedBy       User?                   @relation("NotificationRuleDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  executions      NotificationExecution[]

  @@unique([organizationId, eventKey])
  @@index([organizationId, enabled])
  @@index([organizationId, deletedAt])
}

// =============================================================================
// NOTIFICATIONS (event ingest)
// =============================================================================

enum EventIngestStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  SKIPPED
}

model EventIngest {
  id             String            @id @default(uuid())
  organizationId String
  correlationId  String
  eventKey       String
  idempotencyKey String
  recipientPhone String
  payload        Json
  status         EventIngestStatus @default(RECEIVED)
  errorMessage   String?
  apiKeyId       String?
  processedAt    DateTime?         @db.Timestamptz(3)
  createdAt      DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime          @updatedAt @db.Timestamptz(3)

  organization Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  executions   NotificationExecution[]

  @@unique([organizationId, idempotencyKey])
  @@index([organizationId, createdAt(sort: Desc)])
  @@index([correlationId])
  @@index([eventKey, status])
  @@index([status, createdAt])
}

enum NotificationSource {
  EVENT
  MANUAL
  INTERNAL
  CAMPAIGN
  WEBHOOK
}

enum ExecutionStatus {
  QUEUED
  PROCESSING
  SENT
  FAILED
  SKIPPED
}

model NotificationExecution {
  id                 String             @id @default(uuid())
  organizationId     String
  correlationId      String
  eventIngestId      String?
  notificationRuleId String?
  ruleVersion        Int?
  templateVersionId  String?
  messageId          String?            @unique
  source             NotificationSource
  status             ExecutionStatus    @default(QUEUED)
  skipReason         String?
  errorMessage       String?
  createdAt          DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime           @updatedAt @db.Timestamptz(3)

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  eventIngest      EventIngest?      @relation(fields: [eventIngestId], references: [id], onDelete: SetNull)
  notificationRule NotificationRule? @relation(fields: [notificationRuleId], references: [id], onDelete: SetNull)
  templateVersion  TemplateVersion?  @relation(fields: [templateVersionId], references: [id], onDelete: SetNull)
  message          Message?          @relation(fields: [messageId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([correlationId])
  @@index([eventIngestId])
  @@index([status, createdAt])
}

// =============================================================================
// MESSAGES
// =============================================================================

enum MessageProvider {
  META
}

enum MessageDirection {
  OUTBOUND
  INBOUND
}

enum MessageType {
  TEMPLATE
  TEXT
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
  INTERACTIVE
  UNKNOWN
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

model Message {
  id                 String           @id @default(uuid())
  organizationId     String
  phoneNumberId      String
  provider           MessageProvider  @default(META)
  correlationId      String?
  direction          MessageDirection @default(OUTBOUND)
  recipientPhone     String
  type               MessageType      @default(TEMPLATE)
  templateVersionId  String?
  metaTemplateName   String?
  metaMessageId      String?          @unique
  metaConversationId String?
  status             MessageStatus    @default(QUEUED)
  components         Json?
  bodyText           String?
  errorCode          String?
  errorMessage       String?
  pricingCategory    String?
  pricingModel       String?
  billable           Boolean?
  metaCost           Decimal?         @db.Decimal(12, 6)
  currency           String?
  sentAt             DateTime?        @db.Timestamptz(3)
  deliveredAt        DateTime?        @db.Timestamptz(3)
  readAt             DateTime?        @db.Timestamptz(3)
  failedAt           DateTime?        @db.Timestamptz(3)
  createdAt          DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime         @updatedAt @db.Timestamptz(3)

  organization    Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  phoneNumber     PhoneNumber            @relation(fields: [phoneNumberId], references: [id], onDelete: Restrict)
  templateVersion TemplateVersion?       @relation(fields: [templateVersionId], references: [id], onDelete: SetNull)
  execution       NotificationExecution?

  @@index([organizationId, createdAt(sort: Desc)])
  @@index([organizationId, recipientPhone])
  @@index([organizationId, status, createdAt(sort: Desc)])
  @@index([correlationId])
  @@index([metaConversationId])
}

// =============================================================================
// WEBHOOKS
// =============================================================================

enum WebhookEventType {
  MESSAGES
  MESSAGE_TEMPLATE_STATUS_UPDATE
  PHONE_NUMBER_QUALITY_UPDATE
  UNKNOWN
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
}

model WebhookEvent {
  id             String             @id @default(uuid())
  organizationId String?
  metaWabaId     String?
  metaEventId    String?            @unique
  correlationId  String?
  eventType      WebhookEventType   @default(UNKNOWN)
  payload        Json
  status         WebhookEventStatus @default(RECEIVED)
  attemptCount   Int                @default(0)
  errorMessage   String?
  receivedAt     DateTime           @default(now()) @db.Timestamptz(3)
  processedAt    DateTime?          @db.Timestamptz(3)
  createdAt      DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime           @updatedAt @db.Timestamptz(3)

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([status, receivedAt])
  @@index([metaWabaId, receivedAt(sort: Desc)])
  @@index([correlationId])
  @@index([organizationId, receivedAt(sort: Desc)])
}

model OutboundWebhookConfig {
  id             String   @id @default(uuid())
  organizationId String   @unique
  url            String
  secretEnc      String
  enabled        Boolean  @default(true)
  createdById    String?
  updatedById    String?
  createdAt      DateTime @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime @updatedAt @db.Timestamptz(3)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User?        @relation("OutboundWebhookCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?        @relation("OutboundWebhookUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([enabled])
}
