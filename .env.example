NODE_ENV=development
PORT=4010
LOG_LEVEL=info

# All variables below are read at container/process startup (CapRover env vars).
# Change them in CapRover and restart the app — no image rebuild required.

# PostgreSQL (required from PR-2 onward)
POSTGRES_URI=postgresql://user:password@localhost:5432/trizendialog

# Optional dev database — set USE_DEV_DATABASE=true to route app + Prisma CLI here (non-production only)
POSTGRES_URI_DEV=postgresql://user:password@localhost:5432/trizendialog_dev
USE_DEV_DATABASE=false

# Redis (required for queues from PR-4 onward)
REDIS_URL=redis://localhost:6379

# Auth (PR-2)
JWT_SECRET=change-me-in-production-min-16-chars
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=64-char-hex-32-bytes-for-aes-gcm

# Service-to-service (PR-9 internal trigger API)
SERVICE_AUTH_TOKEN=

# WhatsApp send rate limiting (PR-9)
WHATSAPP_SEND_RATE_LIMIT_MAX=80
WHATSAPP_SEND_RATE_LIMIT_WINDOW_MS=1000

# CORS — REQUIRED in production (runtime CapRover env, restart backend to apply).
# Exact browser origin(s) of the TrizenDialog console — no path, no trailing slash.
# Production frontend: https://wa-dialog-frontend.backend.extrahand.in
CORS_ORIGIN=http://localhost:5173
# Production example (CapRover backend env):
# CORS_ORIGIN=https://wa-dialog-frontend.backend.extrahand.in
# Optional shorthand — merged into the CORS allowlist:
# FRONTEND_URL=https://wa-dialog-frontend.backend.extrahand.in

# Meta (PR-3)
META_API_VERSION=v23.0
# Meta app ID — required for template header media upload (Resumable Upload API)
META_APP_ID=
META_WEBHOOK_VERIFY_TOKEN=

# Seed (PR-2)
SEED_ADMIN_EMAIL=admin@trizenventures.com
SEED_ADMIN_PASSWORD=change-me-min-8-chars
